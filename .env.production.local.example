# Copy to .env.production.local for local production Docker testing.
# This file is only for your machine. Do not commit real secrets.

PROD_ENV_FILE=.env.production.local

SERVER_IMAGE=kasa-starter-kit-api:local-prod
CLIENT_IMAGE=kasa-starter-kit-client:local-prod

CLIENT_PORT=3000
SERVER_PORT=8000
POSTGRES_PORT=5434

NODE_ENV=production
APP_URL=http://localhost:8000
APP_PORT=8000
FRONT_END_URL=http://localhost:3000
API_VERSION=0.1.1

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=kasa-starter-kit
DATABASE_PASSWORD=change-me-local
DATABASE_NAME=kasa-starter-kit
DATABASE_SYNC=false
DATABASE_AUTO_LOAD=true

POSTGRES_USER=kasa-starter-kit
POSTGRES_PASSWORD=change-me-local
POSTGRES_DB=kasa-starter-kit
POSTGRES_VOLUME_NAME=kasa-starter-kit-prod_postgres_data
REDIS_VOLUME_NAME=kasa-starter-kit-prod_redis_data

JWT_SECRET=change-me-local-prod-jwt-secret
JWT_TOKEN_AUDIENCE=http://localhost:3000
JWT_TOKEN_ISSUER=http://localhost:8000
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400

REDIS_HOST=redis
REDIS_PORT=6379

# Local production-test encryption key.
APP_ENCRYPTION_KEY=superkey-my

LICENSE_PORTAL_URL=http://localhost:5000
LICENSE_PRODUCT_SLUG=kasa-starter-kit

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://server:8000
