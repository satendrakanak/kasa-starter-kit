# Copy to .env.production on the production server.
# Never commit the real .env.production file.

SERVER_IMAGE=ghcr.io/YOUR_GITHUB_OWNER/codewithkasa-server:latest
CLIENT_IMAGE=ghcr.io/YOUR_GITHUB_OWNER/codewithkasa-client:latest

CLIENT_PORT=3000
SERVER_PORT=8000
POSTGRES_PORT=5432

NODE_ENV=production
APP_URL=https://api.your-domain.com
APP_PORT=8000
FRONT_END_URL=https://your-domain.com
API_VERSION=0.1.1

# Recommended: use a managed PostgreSQL database in production.
DATABASE_HOST=your-managed-postgres-host
DATABASE_PORT=5432
DATABASE_USER=your-db-user
DATABASE_PASSWORD=your-db-password
DATABASE_NAME=kasa_enterprise
DATABASE_SYNC=false
DATABASE_AUTO_LOAD=true

# Used by the bundled Postgres container in docker-compose.prod.yml.
# If you use managed Postgres, keep DATABASE_* above pointed to managed DB.
POSTGRES_USER=codewithkasa
POSTGRES_PASSWORD=replace-with-production-db-password
POSTGRES_DB=kasa_enterprise

JWT_SECRET=replace-with-a-long-random-secret
JWT_TOKEN_AUDIENCE=https://your-domain.com
JWT_TOKEN_ISSUER=https://api.your-domain.com
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400

REDIS_HOST=redis
REDIS_PORT=6379

APP_ENCRYPTION_KEY=replace-with-a-long-random-secret

LICENSE_PORTAL_URL=https://license.your-domain.com
LICENSE_PRODUCT_SLUG=kasa-enterprise

NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_API_BASE_URL=http://server:8000
