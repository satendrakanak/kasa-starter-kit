#!/usr/bin/env sh
set -eu

SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="$(dirname -- "$SCRIPT_PATH")/$LINK_TARGET" ;;
  esac
done

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
cd "$ROOT_DIR"

usage() {
  cat <<'USAGE'
Kasa Enterprise CLI

Usage:
  kasa install dev [-r|--reset]
  kasa install app
  kasa start dev
  kasa start app
  kasa reset dev
  kasa stop
  kasa restart dev
  kasa restart app

Examples:
  kasa install dev
  kasa install dev -r
  kasa install app
  kasa start dev
  kasa start app
  kasa stop
USAGE
}

command="${1:-}"
target="${2:-}"
flag="${3:-}"

case "$command:$target" in
  install:dev)
    if [ "$flag" = "-r" ] || [ "$flag" = "--reset" ]; then
      ./scripts/reset-dev.sh
    fi
    ./scripts/install-dev.sh
    ;;
  install:app)
    ./scripts/install-app.sh
    ;;
  start:dev)
    ./scripts/start-dev.sh
    ;;
  start:app)
    ./scripts/start-app.sh
    ;;
  reset:dev)
    ./scripts/reset-dev.sh
    ;;
  stop:)
    ./scripts/stop.sh
    ;;
  restart:dev)
    ./scripts/stop-dev.sh
    ./scripts/start-dev.sh
    ;;
  restart:app)
    ./scripts/stop-app.sh
    ./scripts/start-app.sh
    ;;
  *)
    usage
    exit 1
    ;;
esac
