# Copy this file to .env.production on the Oracle VM.
# Never commit the real .env.production file.

# Domains
STARTER_DOMAIN=starter.example.com
STARTER_API_DOMAIN=starter-api.example.com
ACME_EMAIL=admin@example.com

# Public app URLs
NEXT_PUBLIC_APP_URL=https://starter.example.com
NEXT_PUBLIC_API_BASE_URL=http://server:8000
APP_URL=https://starter-api.example.com
FRONT_END_URL=https://starter.example.com
API_VERSION=0.1.1

# Database inside Docker
POSTGRES_USER=kasa_starter
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_DB=kasa_starter
POSTGRES_VOLUME_NAME=kasa-starter-kit-live_postgres_data

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=kasa_starter
DATABASE_PASSWORD=replace-with-long-random-password
DATABASE_NAME=kasa_starter
DATABASE_SYNC=false
DATABASE_AUTO_LOAD=true

# Redis inside Docker
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_VOLUME_NAME=kasa-starter-kit-live_redis_data

# Auth and encryption
JWT_SECRET=replace-with-long-random-jwt-secret
JWT_TOKEN_AUDIENCE=https://starter.example.com
JWT_TOKEN_ISSUER=https://starter-api.example.com
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400
APP_ENCRYPTION_KEY=replace-with-long-random-encryption-key

# License activation
LICENSE_PORTAL_URL=https://license.example.com
LICENSE_PRODUCT_SLUG=kasa-starter-kit

# Caddy volumes
CADDY_DATA_VOLUME=kasa-starter-kit-live_caddy_data
CADDY_CONFIG_VOLUME=kasa-starter-kit-live_caddy_config
